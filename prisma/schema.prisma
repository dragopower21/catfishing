generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id
  displayName  String?   @unique
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ArticleSet {
  id          String        @id @default(cuid())
  name        String
  description String?
  ownerId     String
  hidden      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  articles    Article[]
  plays       PlaySession[]

  @@index([ownerId])
}

model Article {
  id              String     @id @default(cuid())
  setId           String
  set             ArticleSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  title           String
  wikipediaUrl    String
  wikipediaPageId Int
  categories         String
  disabledCategories String     @default("[]")
  customHints        String     @default("[]")
  aliases            String
  customAliases      String     @default("[]")
  summary         String?
  thumbnailUrl    String?
  pageViews       Int?
  difficultyScore Int?
  orderIndex      Int        @default(0)
  createdAt       DateTime   @default(now())

  @@index([setId])
}

model PlaySession {
  id         String     @id @default(cuid())
  setId      String
  set        ArticleSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  players    String
  results    String
  finishedAt DateTime   @default(now())
}

// -- Multiplayer lobbies ---------------------------------------------------

model Lobby {
  id                 String   @id @default(cuid())
  code               String   @unique
  mode               String   // "FREESTYLE" | "SET_BASED"
  setId              String?  // for SET_BASED
  passwordHash       String?
  status             String   @default("WAITING") // "WAITING" | "IN_GAME" | "ENDED"
  roundDuration      Int      @default(80)
  totalRounds        Int      @default(8)
  currentRoundNumber Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members  LobbyMember[]
  rounds   LobbyRound[]
  messages LobbyMessage[]

  @@index([code])
}

model LobbyMember {
  id          String   @id @default(cuid())
  lobbyId     String
  lobby       Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  userId      String   // owner cookie
  displayName String
  score       Int      @default(0)
  isHost      Boolean  @default(false)
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  messages LobbyMessage[]

  @@unique([lobbyId, userId])
  @@index([lobbyId])
}

model LobbyRound {
  id                   String   @id @default(cuid())
  lobbyId              String
  lobby                Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  roundNumber          Int
  pickerMemberId       String?
  status               String   @default("PICKING") // PICKING | ACTIVE | ENDED
  articleTitle         String?
  articleUrl           String?
  articlePageId        Int?
  articleCategories    String?  // JSON string[]
  articleAliases       String?  // JSON string[]
  articleCustomHints   String?  // JSON string[] — picker-added extra clues
  articleCustomAliases String?  // JSON string[]
  articleSummary       String?
  articleThumbnailUrl  String?
  articleDifficulty    Int?
  startsAt             DateTime?
  /// Dual-purpose: in ACTIVE state this is the timer end; in ENDED
  /// state this is the time at which the next round may start (reveal
  /// window).
  endsAt               DateTime?
  createdAt            DateTime @default(now())

  @@unique([lobbyId, roundNumber])
}

model LobbyMessage {
  id          String   @id @default(cuid())
  lobbyId     String
  lobby       Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  memberId    String?
  member      LobbyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  displayName String   // snapshot at send time
  text        String?  // null for CORRECT_GUESS (to hide answer)
  type        String   @default("CHAT") // CHAT | SYSTEM | CORRECT_GUESS
  points      Int?     // filled for CORRECT_GUESS
  roundId     String?  // which round this message belongs to (null for waiting-room chat)
  orderIndex  Int?     // for CORRECT_GUESS: 0-based order among correct guessers this round
  createdAt   DateTime @default(now())

  @@index([lobbyId, createdAt])
  @@index([roundId])
}
