generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id
  displayName  String?   @unique
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ArticleSet {
  id          String        @id @default(cuid())
  name        String
  description String?
  ownerId     String
  hidden      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  articles    Article[]
  plays       PlaySession[]

  @@index([ownerId])
}

model Article {
  id              String     @id @default(cuid())
  setId           String
  set             ArticleSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  title           String
  wikipediaUrl    String
  wikipediaPageId Int
  categories         String
  disabledCategories String     @default("[]")
  customHints        String     @default("[]")
  aliases            String
  customAliases      String     @default("[]")
  summary         String?
  thumbnailUrl    String?
  pageViews       Int?
  difficultyScore Int?
  orderIndex      Int        @default(0)
  createdAt       DateTime   @default(now())

  @@index([setId])
}

model PlaySession {
  id         String     @id @default(cuid())
  setId      String
  set        ArticleSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  players    String
  results    String
  finishedAt DateTime   @default(now())
}
